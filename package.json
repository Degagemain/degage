{
  "name": "open-cars",
  "version": "1.0.0",
  "scripts": {
    "predev": "pnpm db:start",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --config .prettierrc --check .",
    "format:fix": "prettier --config .prettierrc --write .",
    "fix": "pnpm lint:fix && pnpm format:fix",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:reset": "docker compose down --volumes --remove-orphans && pnpm db:start && pnpm db:migrate && pnpm db:seed",
    "db:migrate": "dotenv -e .env -- prisma migrate dev",
    "db:seed": "dotenv -e .env -- prisma db seed",
    "docs": "node scripts/validate-docs.mjs",
    "benchmark": "dotenv -e .env -- pnpx tsx scripts/benchmark.ts"
  },
  "keywords": [],
  "author": "Mathias Colpaert",
  "license": "GPL-3.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "overrides": {
      "protobufjs": "^7.5.5"
    }
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.53",
